{
  "manifest_version": 3,
  "name": "SGB Güvenli Web",
  "version": "1.0",
  "description": "Siber Güvenlik Başkanlığı API'ını kullanarak zararlı web sitelerini engeller.",
  "permissions": [
    "webNavigation",
    "storage"
  ],
  "host_permissions": [
    "https://siberguvenlik.gov.tr/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "src/ui/options/index.html",
  "action": {
    "default_popup": "src/ui/popup/index.html"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
